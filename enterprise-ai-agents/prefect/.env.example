# Azure AI Foundry (the LLM provider). Copy to .env and fill in.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-10-21

# GitHub (for the issue review agent). A personal access token (classic or
# fine-grained) with read access to the repos you review. api.github.com by
# default; override GITHUB_API_URL for GitHub Enterprise.
GITHUB_TOKEN=
# GITHUB_API_URL=https://github.your-company.com/api/v3

# Source Postgres (demo data). Default points at the Dockerized sources-db.
SOURCES_DSN=postgresql://reader:reader@localhost:5436/sources

# Memory Postgres. Default points at the Dockerized memory-db.
MEMORY_DSN=postgresql://agent:agent@localhost:5433/memory

# Opik tracing. Set OPIK_TRACING_ENABLED=true to enable.
# OPIK_URL_OVERRIDE: point at your self-hosted instance (default port 5173).
# OPIK_API_KEY: generate one from the local Opik UI (Settings → API keys).
OPIK_TRACING_ENABLED=false
OPIK_URL_OVERRIDE=http://localhost:5173/api
OPIK_API_KEY=
